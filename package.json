{
  "name": "gloomhaven",
  "version": "0.1.0",
  "description": "An easy-to-use collection of data and images from Gloomhaven by Cephalofair Games.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/any2cards/gloomhaven.git"
  },
  "author": "William Habush <any2cards@yahoo.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/any2cards/gloomhaven/issues"
  },
  "homepage": "https://github.com/any2cards/gloomhaven",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "vite build && npm run copy:images",
    "copy:images": "mkdir -p dist/images && cp -R images/. dist/images/",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run dev",
    "test": "node --test \"tests/**/*.test.ts\"",
    "test:domain": "node --test \"tests/domain/*.test.ts\"",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
